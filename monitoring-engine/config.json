{
  "engine": {
    "rpcUrl": "http://127.0.0.1:8545",
    "freezeThreshold": 20,
    "decayRatePerMinute": 5,
    "evaluationIntervalMs": 10000
  },
  "rules": {
    "rapidTransactions": {
      "name": "Rapid Tx Spam",
      "timeWindowMs": 60000,
      "thresholds": [
        { "count": 2, "score": 40, "level": "WARNING" },
        { "count": 3, "score": 75, "level": "CRITICAL" }
      ]
    },
    "largeVolume": {
      "name": "Cumulative Percentage Drain",
      "timeWindowMs": 60000,
      "thresholds": [
        { "percentage": 10, "score": 50, "level": "WARNING" },
        { "percentage": 20, "score": 100, "level": "CRITICAL" }
      ]
    }
  }
}
